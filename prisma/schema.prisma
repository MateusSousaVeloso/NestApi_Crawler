generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                @id @default(dbgenerated("gen_random_uuid()"))
  name             String
  phone_number     String                @unique
  email            String                @unique
  password         String
  createdAt        DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  preferences      Json?
  token            String?
  tokenIssuedAt    DateTime?             @db.Timestamptz(6)
  tokenUserAgent   String?
  tokenIpAddress   String?
  chat_sessions    chat_sessions[]
  user_api_keys    user_api_keys?
  routePreferences UserRoutePreference[]
  subscriptions    UserSubscription?
  milhasMessages   milhas_message[]
  tripInfo         TripInfo?
  userSearches     UserSearch[]

  @@map("users")
}

model UserSearch {
  id              String             @id @default(dbgenerated("gen_random_uuid()"))
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String             @db.VarChar(20)
  status          UserSearchStatus   @default(pending)
  priority        Boolean            @default(false)
  searchTimestamp DateTime           @default(now()) @db.Timestamptz(6)
  startedAt       DateTime?          @db.Timestamptz(6)
  completedAt     DateTime?          @db.Timestamptz(6)
  params          Json
  errorMessage    String?
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  results         UserSearchResult[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("user_searches")
}

model UserSearchResult {
  id           String             @id @default(dbgenerated("gen_random_uuid()"))
  userSearchId String
  userSearch   UserSearch         @relation(fields: [userSearchId], references: [id], onDelete: Cascade)
  resultId     String
  result       FlightSearchResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now()) @db.Timestamptz(6)

  @@unique([userSearchId, resultId])
  @@index([userSearchId])
  @@index([resultId])
  @@map("user_search_results")
}

enum UserSearchStatus {
  pending
  doing
  done
  error
}

model milhas_message {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("milhas_messages")
}

model TripInfo {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  origin        String?    @db.VarChar(10)
  destination   String?    @db.VarChar(10)
  departureDate DateTime?  @db.Date
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  userPhone     String     @unique @db.VarChar(20)
  tipoBusca     TipoBusca?
  finalDate     DateTime?  @db.Date
  CabinType     CabinType?
  user          User       @relation(fields: [userPhone], references: [phone_number], onDelete: Cascade)

  @@map("trip_info")
}

enum TipoBusca {
  preco
  custo_beneficio
}

model SubscriptionPlan {
  id           Int                @id
  name         String
  price        Decimal            @db.Decimal(10, 2)
  durationDays Int
  users        UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id           String             @id @default(dbgenerated("gen_random_uuid()"))
  payment_date DateTime           @default(now())
  end_date     DateTime
  planId       Int
  userId       String             @unique
  status       SubscriptionStatus @default(active)
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id])
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, end_date])
  @@map("user_subscriptions")
}


model UserRoutePreference {
  id              String         @id @default(dbgenerated("gen_random_uuid()"))
  originCity      String         @db.VarChar(100)
  originIata      String         @db.VarChar(10)
  destinationCity String         @db.VarChar(100)
  destinationIata String         @db.VarChar(10)
  provider        String         @default("smiles") @db.VarChar(20)
  cabinType       CabinType      @default(ANY)
  alertFrequency  AlertFrequency @default(DAILY)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  userId          String
  dateEnd         DateTime?      @db.Date
  dateStart       DateTime?      @db.Date
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("user_route_preferences")
}


model FlightSearchResult {
  id               String               @id @default(dbgenerated("gen_random_uuid()"))
  flightDate       DateTime             @db.Date
  searchedAt       DateTime             @default(now())
  origin           String               @db.VarChar(10)
  destination      String               @db.VarChar(10)
  provider         String               @db.VarChar(30)
  economyMinMiles  Int?
  premiumMinMiles  Int?
  businessMinMiles Int?
  firstMinMiles    Int?
  businessMinJson  Json?
  economyMinJson   Json?
  firstMinJson     Json?
  premiumMinJson   Json?
  details          FlightSearchDetail[]
  userSearches     UserSearchResult[]
  history          FlightSearchResultHistory[]

  @@unique([origin, destination, flightDate, provider])
  @@index([origin, destination])
  @@index([flightDate])
  @@index([searchedAt])
  @@map("flight_search_results")
}

model FlightSearchDetail {
  id               String             @id @default(dbgenerated("gen_random_uuid()"))
  searchResultId   String
  uid              String?            @db.VarChar(500)
  flightCode       String?            @db.VarChar(150)
  airline          String?            @db.VarChar(100)
  cabin            String             @db.VarChar(30)
  cabinClass       String?            @db.VarChar(10)
  availableSeats   Int                @default(0)
  stops            Int                @default(0)
  departureTime    String             @db.VarChar(15)
  departureAirport String             @db.VarChar(10)
  arrivalTime      String             @db.VarChar(15)
  arrivalAirport   String             @db.VarChar(10)
  departureDate    DateTime?
  arrivalDate      DateTime?
  durationHours    Int                @default(0)
  durationMinutes  Int                @default(0)
  miles            Int                @default(0)
  price            Decimal?           @db.Decimal(10, 2)
  currency         String?            @db.VarChar(10)
  route            String             @db.VarChar(200)
  legsJson         Json?
  searchResult     FlightSearchResult @relation(fields: [searchResultId], references: [id], onDelete: Cascade)

  @@index([searchResultId])
  @@index([airline])
  @@index([cabin])
  @@map("flight_search_details")
}

model FlightSearchResultHistory {
  id               String                      @id @default(dbgenerated("gen_random_uuid()"))
  originalResultId String?
  originalResult   FlightSearchResult?         @relation(fields: [originalResultId], references: [id], onDelete: SetNull)
  flightDate       DateTime                    @db.Date
  searchedAt       DateTime
  snapshotAt       DateTime                    @default(now())
  origin           String                      @db.VarChar(10)
  destination      String                      @db.VarChar(10)
  provider         String                      @db.VarChar(30)
  economyMinMiles  Int?
  premiumMinMiles  Int?
  businessMinMiles Int?
  firstMinMiles    Int?
  economyMinJson   Json?
  premiumMinJson   Json?
  businessMinJson  Json?
  firstMinJson     Json?
  details          FlightSearchDetailHistory[]

  @@index([originalResultId])
  @@index([origin, destination, flightDate, provider])
  @@index([snapshotAt])
  @@map("flight_search_result_history")
}

model FlightSearchDetailHistory {
  id               String                    @id @default(dbgenerated("gen_random_uuid()"))
  resultHistoryId  String
  resultHistory    FlightSearchResultHistory @relation(fields: [resultHistoryId], references: [id], onDelete: Cascade)
  uid              String?                   @db.VarChar(500)
  flightCode       String?                   @db.VarChar(150)
  airline          String?                   @db.VarChar(100)
  cabin            String                    @db.VarChar(30)
  cabinClass       String?                   @db.VarChar(10)
  availableSeats   Int                       @default(0)
  stops            Int                       @default(0)
  departureTime    String                    @db.VarChar(15)
  departureAirport String                    @db.VarChar(10)
  arrivalTime      String                    @db.VarChar(15)
  arrivalAirport   String                    @db.VarChar(10)
  departureDate    DateTime?
  arrivalDate      DateTime?
  durationHours    Int                       @default(0)
  durationMinutes  Int                       @default(0)
  miles            Int                       @default(0)
  price            Decimal?                  @db.Decimal(10, 2)
  currency         String?                   @db.VarChar(10)
  route            String                    @db.VarChar(200)
  legsJson         Json?

  @@index([resultHistoryId])
  @@map("flight_search_detail_history")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id            String         @id
  sessionId     String
  content       String
  role          ChatRole
  modelProvider ModelProvider?
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  chat_sessions chat_sessions  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_sessions {
  id               String          @id
  userId           String
  title            String?         @default("Sem título")
  summary          String          @default("")
  userMessageCount Int             @default(0)
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @db.Timestamptz(6)
  chat_messages    chat_messages[]
  users            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_api_keys {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  userId          String    @unique
  geminiKey       String?
  claudeKey       String?
  openaiKey       String?
  claudeUpdatedAt DateTime? @db.Timestamptz(6)
  geminiUpdatedAt DateTime? @db.Timestamptz(6)
  openaiUpdatedAt DateTime? @db.Timestamptz(6)
  users           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}


enum CabinType {
  ANY
  ECONOMIC
  BUSINESS
  FIRST
}

enum AlertFrequency {
  DAILY
  EVERY_6_HOURS
  EVERY_12_HOURS
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}

enum ChatRole {
  user
  assistant
  system
}

enum ModelProvider {
  claude
  gpt
  gemini
}
