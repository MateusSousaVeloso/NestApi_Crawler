generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                @id @default(dbgenerated("gen_random_uuid()"))
  name             String
  phone_number     String                @unique
  email            String                @unique
  password         String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  preferences      Json?
  token            String?               @unique
  histories        History[]
  tripInfo         TripInfo?
  routePreferences UserRoutePreference[]
  subscriptions    UserSubscription?

  @@map("users")
}

model SubscriptionPlan {
  id           Int                @id
  name         String
  price        Decimal            @db.Decimal(10, 2)
  durationDays Int
  users        UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id           String           @id @default(dbgenerated("gen_random_uuid()"))
  payment_date DateTime         @default(now())
  end_date     DateTime
  status       String           @default("active")
  planId       Int
  userPhone    String           @unique @db.VarChar(20)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  user         User             @relation(fields: [userPhone], references: [phone_number], onDelete: Cascade)

  @@map("user_subscriptions")
}

model History {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  session_id String
  message    Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [session_id], references: [phone_number], onDelete: Cascade)

  @@index([session_id])
  @@map("histories")
}

enum TipoBusca {
  preco
  custo_beneficio
}

enum CabinType {
  ANY
  ECONOMY
  BUSINESS
  FIRST
}

enum AlertFrequency {
  DAILY
  EVERY_6_HOURS
  EVERY_12_HOURS
}

model UserRoutePreference {
  id              String         @id @default(dbgenerated("gen_random_uuid()"))
  originCity      String         @db.VarChar(100)
  originIata      String         @db.VarChar(10)
  destinationCity String         @db.VarChar(100)
  destinationIata String         @db.VarChar(10)
  cabinType       CabinType      @default(ANY)
  alertFrequency  AlertFrequency @default(DAILY)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  dateEnd         DateTime?      @db.Date
  dateStart       DateTime?      @db.Date
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_route_preferences")
}

model TripInfo {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  origin        String?    @db.VarChar(10)
  destination   String?    @db.VarChar(10)
  departureDate DateTime?  @db.Date
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  userPhone     String     @unique @db.VarChar(20)
  tipoBusca     TipoBusca?
  finalDate     DateTime?  @db.Date
  CabinType     CabinType?
  user          User       @relation(fields: [userPhone], references: [phone_number], onDelete: Cascade)

  @@map("trip_info")
}

model FlightSearchResult {
  id                String   @id @default(dbgenerated("gen_random_uuid()"))
  flightDate        DateTime @db.Date
  searchedAt        DateTime @default(now())
  origin            String   @db.VarChar(10)
  destination       String   @db.VarChar(10)
  provider          String   @db.VarChar(30)
  economyMinMiles   Int?
  premiumMinMiles   Int?
  businessMinMiles  Int?
  firstMinMiles     Int?
  economyMinJson    Json?
  premiumMinJson    Json?
  businessMinJson   Json?
  firstMinJson      Json?
  details           FlightSearchDetail[]

  @@unique([origin, destination, flightDate, provider])
  @@index([origin, destination])
  @@index([flightDate])
  @@index([searchedAt])
  @@map("flight_search_results")
}

model FlightSearchDetail {
  id               String             @id @default(dbgenerated("gen_random_uuid()"))
  searchResultId   String
  uid              String?            @db.VarChar(50)
  flightCode       String?            @db.VarChar(150)
  airline          String?            @db.VarChar(100)
  cabin            String             @db.VarChar(30)
  cabinClass       String?            @db.VarChar(10)
  availableSeats   Int                @default(0)
  stops            Int                @default(0)
  departureTime    String             @db.VarChar(15)
  departureAirport String             @db.VarChar(10)
  arrivalTime      String             @db.VarChar(15)
  arrivalAirport   String             @db.VarChar(10)
  departureDate    DateTime?
  arrivalDate      DateTime?
  durationHours    Int                @default(0)
  durationMinutes  Int                @default(0)
  miles            Int                @default(0)
  price            Decimal?           @db.Decimal(10, 2)
  currency         String?            @db.VarChar(10)
  route            String             @db.VarChar(200)
  legsJson         Json?
  searchResult     FlightSearchResult @relation(fields: [searchResultId], references: [id], onDelete: Cascade)

  @@index([searchResultId])
  @@index([airline])
  @@index([cabin])
  @@map("flight_search_details")
}
